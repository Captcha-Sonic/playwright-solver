# ─── CaptchaSonic Configuration ───────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your CaptchaSonic API key (required for all examples)
# Get your key at: https://captchasonic.com
CAPTCHASONIC_API_KEY=sonic_your_key_here

# Path to built CaptchaSonic extension (required for extension examples only)
# Build: cd captcha-sonic-ext && npm run build:chrome
CAPTCHASONIC_EXT_PATH=/path/to/captcha-sonic-ext/.output/chrome-mv3
